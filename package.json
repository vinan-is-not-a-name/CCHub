{
  "name": "cchub",
  "version": "0.1.0",
  "description": "Access Claude Code CLI via web browser",
  "license": "MIT",
  "author": "vinan-is-not-a-name",
  "repository": {
    "type": "git",
    "url": "https://github.com/vinan-is-not-a-name/CCHub.git"
  },
  "bugs": {
    "url": "https://github.com/vinan-is-not-a-name/CCHub/issues"
  },
  "homepage": "https://github.com/vinan-is-not-a-name/CCHub#readme",
  "keywords": [
    "claude-code",
    "terminal",
    "web",
    "ssh",
    "llm",
    "mcp"
  ],
  "type": "module",
  "bin": {
    "cchub": "./dist/server/entry/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.server.json && tsc -p tsconfig.client.json && node scripts/build.js",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json",
    "dev": "concurrently -k \"tsx watch src/server/entry/index.ts\" \"node scripts/build.js --watch\"",
    "start": "node dist/server/entry/index.js",
    "test": "playwright test"
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.0.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@xterm/headless": "^6.0.0",
    "fastify": "^5.0.0",
    "node-pty": "^1.0.0",
    "ssh2": "^1.17.0",
    "xterm-theme": "^1.1.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.0.0",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "^8.18.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "concurrently": "^9.0.0",
    "esbuild": "^0.25.0",
    "playwright": "^1.60.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
